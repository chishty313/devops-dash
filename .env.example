# Copy to .env at repo root (used by docker compose on the VM and locally for compose).
# cp .env.example .env

# Public URL (Grafana subpath, docs)
DOMAIN=qtec.chishty.me

# Backend
NODE_ENV=production
APP_VERSION=1.0.0
LOG_LEVEL=info

# MongoDB Atlas only (no local mongo container).
# In Atlas: Database -> Connect -> Drivers -> copy SRV string.
# Include database name before ? e.g. ...mongodb.net/qtec?retryWrites=true&w=majority
# Network Access: allow your laptop IP for local dev; allow Azure VM public IP (or 0.0.0.0/0 for testing only).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/qtec?retryWrites=true&w=majority&appName=qtec

# Docker images (GHCR)
IMAGE_TAG=latest
COMPOSE_PROJECT_NAME=qtec
# Must match GitHub user/org that owns the GHCR images; use lowercase (GHCR requirement).
GITHUB_OWNER=your-github-username
