# Local development (npm run dev). Copy to backend/.env
# cp .env.example .env

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
APP_VERSION=1.0.0

# Same Atlas URI as production .env (or a separate Atlas user/database for dev).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/qtec?retryWrites=true&w=majority&appName=qtec-dev
